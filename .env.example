# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_PROFILE=default
# Bearer token for direct Bedrock API calls (boto3 path — production/console visibility).
# Get from: AWS Console → IAM → Security credentials → Create access key, OR
# use temporary STS token. Required when migrating away from Nova API.
AWS_BEARER_TOKEN_BEDROCK=

# ── Nova API (api.nova.amazon.com — OpenAI-compatible REST + WebSocket) ────────
# Used by lite_client.py and sonic_client.py for dev. No IAM needed.
# Migrate to boto3 (Bedrock SDK) for production console visibility.
# Get your key at https://api.nova.amazon.com → API Keys
NOVA_API_KEY=

# ── Bedrock model IDs ─────────────────────────────────────────────────────────
BEDROCK_MODEL_SONIC=amazon.nova-sonic-v1:0
BEDROCK_MODEL_LITE=amazon.nova-lite-v1:0
BEDROCK_MODEL_EMBEDDING=amazon.nova-pro-v1:0

# ── Data stores ───────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql+asyncpg://mc:mc@localhost:5432/missioncontrol

# ── S3 ────────────────────────────────────────────────────────────────────────
S3_BUCKET_EVIDENCE=mission-control-evidence-dev

# ── Vector store ──────────────────────────────────────────────────────────────
OPENSEARCH_ENDPOINT=https://<collection>.us-east-1.aoss.amazonaws.com

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEMO_MODE=false
API_KEY=changeme
AGENT_POOL_SIZE=6
BACKEND_URL=http://localhost:8000

# ── Local dev overrides (Docker Compose) ──────────────────────────────────────
# Uncomment these when running against local MinIO instead of real S3.
# docker compose up -d   ←  starts Redis + Postgres + MinIO
#
# AWS_ENDPOINT_URL_S3=http://localhost:9000
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# S3_BUCKET_EVIDENCE=evidence
